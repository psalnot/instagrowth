<script>

    function openMenu() {
        if ($(window).width() >= 768) {
            if (!$("#menu-popup").hasClass("opened")) {
                $("#menu-popup").addClass("opened");
                $("body").addClass("menu-opened");
                $("#sort-menu").removeClass("opened");
            }
        }
    }

    function toggleMenu() {
        if ($("#menu-popup").hasClass("opened")) {
            $("#menu-popup").removeClass("opened");
            $("body").removeClass("menu-opened");
        } else {
            $("#menu-popup").addClass("opened");
            $("body").addClass("menu-opened");
            $("#sort-menu").removeClass("opened");
        }
    }

    function closeMenu() {
        if ($("#menu-popup").hasClass("opened")) {
            $("#menu-popup").removeClass("opened");
            $("body").removeClass("menu-opened");
        }
    }
