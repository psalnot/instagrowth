
body, html, .wrapper,
.content-wrapper {
    height: 100% !important;
}

section.content {
    display: flex;
    padding: 0;
    height: 100%;
    align-items: stretch;
    background: #efedec;
}

#dashboard-links {
    flex-basis: 60%;

    display: flex;
    align-items: stretch;
    flex-grow: 2;
}

#dashboard-links a {
    cursor: pointer;
}

#dashboard-links .links-left {

    flex-grow: 1;
    display: flex;
    align-items: stretch;
    flex-direction: column;
    flex-basis: 50%;
}

#dashboard-links .links-right {

    flex-grow: 1;
    display: flex;
    align-items: stretch;
    flex-direction: column;
    flex-basis: 50%;
}

.fav-link {
    background: url("/mysite/images/fav.jpg") top center no-repeat;
    background-size: cover;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 50%;
    position: relative;
}

.fav-link a {
    z-index: 10;
}

.fav-link:before {
    z-index: 9;
    width: 100%;
    height: 100%;
    content: " ";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    background: #000;
    opacity: 0.3;
}

.fav-link a:focus {
    text-decoration: none;
}

.jobs-link {
    background: url("/mysite/images/jobs-link-bg.jpg") top center no-repeat;
    background-size: cover;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 50%;
}

#right-part {
    margin: 20px;
    flex-basis: 40%;
    max-height: 100%;
    display: flex;
    flex-direction: column;
    min-width: 0;
}

#activities, #suggested {

    background: #fff;
    flex-direction: column;
    padding: 15px;
    box-shadow: 3.29px 2.2px 2.2px rgba(0, 0, 0, 0.15);
    display: flex;

}

#activities {
    flex-grow: 1;
    flex: 1;
    min-height: 0px;
}

#suggested {
    margin-bottom: 20px;
    box-sizing: border-box;
    display: block;
    max-height: none;
    padding-bottom: 0;
}

#suggested-list {
    /*margin-right: -15px;*/
    margin-left: -20px;
    display: block;
}

#suggested .suggested_thumbnail {
    width: 20%;
    -webkit-box-sizing: border-box;
    -moz-box-sizing: border-box;
    box-sizing: border-box;
    margin: 0;
    display: inline-block;
    float: left;
    padding-left: 20px;
    padding-top: 0;
    padding-bottom: 20px;
}

#activities .activity-title {
    font-family: "Messina Sans";

    color: #2a2928;
    font-size: 14px;

    margin-left: 90px;
    margin-top: 15px;
    margin-bottom: 0;
    display: block;
}

#activities .activity-title strong {
    font-weight: bold;
    text-transform: capitalize;
}

#activities .activity-item {
    display: block;
    position: relative;
}

#activities .activity-item hr {
    content: " ";
    position: absolute;
    bottom: 0;
    left: 90px;
    right: 0;
    border: 0;
    padding: 0;
    margin: 0;
    border-top: 1px solid #ccc;

}

#activities .activity-date {
    font-size: 12px;
    color: #8D8D8D;
    display: block;
    margin-top: 5px;
}

#activities .img-circle {
    width: 50px;
    height: 50px;
    margin: 18px;
    text-align: center;
    line-height: 50px;
    text-transform: uppercase;
    display: inline-block;
    background: #959595;
    font-weight: bold;
    color: #fff;
    font-size: 14px;
}

#activities .no-activities {
    height: 100%;
}

.book-link {
    background: url("/mysite/images/book-link-bg.jpg") top center no-repeat;
    background-size: cover;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 50%;
}

.browse-link {
    background: url("/mysite/images/browse-link-bg.jpg") top center no-repeat;
    background-size: cover;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 50%;
}

#dashboard-links a {
    text-transform: uppercase;
    font-family: "FreightDisp Pro";
    font-size: 25px;
    text-align: center;
    color: #fff;
    display: block;
    flex-grow: 1;

}

#dashboard-links hr {
    border-top: 1px solid #f75011;
    width: 30px;
    margin-top: 10px;
}

#dashboard-links a:hover {
    text-decoration: none;
}

.ubooker-thumb {
    width: 50px;
    height: 50px;
    margin: 18px;
    display: inline-block;
    background: #fff url('/mysite/images/ubooker-thumb.svg') center no-repeat;
    -webkit-background-size: 40px 40px;
    background-size: 22px;
    border: 1px solid #efedec;

    border-radius: 50%;
}

#activities-list {
    overflow: auto;
}

#activities-list.loading:after {
    content: " ";
    display: block;
    height: 70px;
    background: #fff url("/mysite/images/chat-loading.gif") center no-repeat;
    background-size: 70px 70px;
}

#activities .notification-item:hover {
    text-decoration: none;
}

#activities .notification-item.unread {
    background: #efedec;
}

@media (max-width: 1024px) {
    section.content {
        flex-direction: column;
    }

    #dashboard-links {
        flex-basis: 70%;
    }

    #right-part {
        flex-basis: 30%;
        margin: 0;
    }

    #suggested {
        height: 100%;
        box-shadow: none;
        margin: 0;
        padding-right: 10px;
        padding-left: 10px;
    }

    #suggested h1.title {
        text-align: center;
        margin-top: 0;
        padding-bottom: 10px;
        font-size: 25px;
    }

    #suggested #suggested-list {
        margin: 0;
    }

    #suggested .suggested-item {
        position: relative;
        width: 17%;
        padding-bottom: 17%;
        overflow: hidden;
        border-radius: 50%;
        margin: 0 1.5% 3% 1.5%;
        float: left;
    }

    #suggested .suggested_thumbnail {
        padding: 0;
        margin: 0;
        width: 100%;
        margin-top: -25%;
        position: absolute;
    }

    #activities {
        display: none;
    }
}

@media (max-width: 767px) {
    #dashboard-links .links-left {
        flex-direction: row;
    }

    #dashboard-links {
        flex-direction: column;
    }

    .links-right {
        flex-direction: row !important;
    }

    .book-link, .browse-link, .fav-link, .jobs-link {
        height: auto;
        width: 50%;
    }

    .wrapper {
        display: flex;
        flex-direction: column;
    }
}

@media (max-width: 475px) {
    #suggested h1.title {
        font-size: 20px;
    }

    section.content {
        overflow: auto;
        background-color: white;
    }

    #dashboard-links {
        /*flex-basis: 70%;*/
    }

    #right-part {
        /*flex-basis: 30%;*/
        max-height: 210px;
        margin: 0;
        background: none;
        background-color: white;
    }

}

@media (max-width: 375px) {
    #suggested h1.title {
        font-size: 18px;
    }
}