function setMessageAsRead(elem, event) {
    // if(unapproved_model){
    //     return;
    // }
    var href = $(elem).closest("[data-message-id]").attr("href");
    if ($(elem).closest("[data-message-id]").hasClass("unread")) {
        event.preventDefault();

        var message_id = $(elem).closest("[data-message-id]").data("message-id");
        $.ajax({
            url: "/message/setMessageAsRead",
            data: {
                message_id: message_id
            },
            success: function (response) {
                try {
                    response = JSON.parse(response);
                }
                catch (e) {
                    alert("Sorry there has been a temporary error, please try again later.");
                    return;
                }
                if (response.success) {
                    location = href;

                }

            }

        })
    }
    var hash = href.split("#");

    if (hash.length == 2) {
        hash = hash[1];
        if (window['openChat'] != undefined && hash != "" && $("[data-hash=" + hash + "]").length > 0) {

            openChat($("[data-hash=" + hash + "]")[0])
        }
    }

}

function openPopup(title, text) {
    var select_models_popup = $("<div>");
    select_models_popup.addClass("custom_popup");
    var select_models_title = $("<h3>");
    select_models_title.addClass("popup_title").html(title)
    select_models_popup.append(select_models_title);
    var select_models_text = $("<p>");
    select_models_text.addClass("description").html(text)
    select_models_popup.append(select_models_text);
    $.magnificPopup.open({
        items: {
            src: select_models_popup,
            type: 'inline'
        }
    });
}

function checkNotifications() {

    var url = "/message/checkNotifications";
    var messages_last_edited = $("#messages-notification").data("messages-last-edited");
    var activities_last_edited = $("#activities-notification").data("activities-last-edited");
    $.ajax({
        method: "GET",
        url: url,
        data: {
            MessagesLastEdited: messages_last_edited,
            ActivitiesLastEdited: activities_last_edited
        },
        success: function (response) {
            setTimeout(function () {
                checkNotifications();
            }, 5000);
            try {
                response = JSON.parse(response);
            } catch (e) {
                response = false;
                return;
            }
            if (response.success) {
                var refresh = false;
                if (response.Messages && messages_last_edited != response.Messages.LastEdited) {
                    $("#messages-count").text(response.Messages.Unread);
                    $("#messages-count").show();
                    $("#messages-notification").data("messages-last-edited", response.Messages.LastEdited);

                    if (!mute) {
                        notification_sound.play();
                    }
                    updateNotifications();
                    if (typeof loadConversations === "function") {
                        loadConversations();
                    }
                }
                if (response.Activities && activities_last_edited != response.Activities.LastEdited) {
                    $("#activities-count").text(response.Activities.Unread);
                    $("#activities-count").show();
                    $("#activities-notification").data("activities-last-edited", response.Activities.LastEdited);
                    notification_sound.play();
                    updateNotifications('Event');
                    if (typeof reloadDetails === "function") {
                        reloadDetails();
                    }


                }

            }

        },
        error: function () {
            setTimeout(function () {
                getNewMessages();
            }, 30000);
        }
    });
}

