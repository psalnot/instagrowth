function updateNotifications(type) {
    if (type === undefined) {
        type = 'Message';
    }
    var url = "/message/updateNotifications";
    $.ajax({
        method: "GET",
        url: url,
        data: {
            type: type
        },
        success: function (response) {
            try {
                response = JSON.parse(response);
            } catch (e) {
                response = false;
                return;
            }
            if (response.success) {
                if (type == "Message") {
                    $("#messages-notification ul.menu").html(response.fragment);
                    if (response.unread > 0) {
                        $("#messages-count").text(response.unread);
                        $("#messages-count").show();
                    } else {
                        $("#messages-count").hide();
                    }
                    replaceNotificationMessageEmoji();
                }
                if (type == "Event") {
                    $("#activities-notification ul.menu").html(response.fragment);
                }
            }

        },
        error: function () {

        }
    });
}

function loadNextActivities(elem) {
    var scroll_bottom = elem.scrollHeight - elem.clientHeight;
    var current_scroll_pos = elem.scrollTop;
    var start = $(elem).data("start");
    var template = $(elem).data("template");
    var element = $(elem);
    if (current_scroll_pos > scroll_bottom - 50 && start != -1 && !element.hasClass("loading")) {
        element.addClass("loading");
        start += 15;
        element.data("start", start);
        var url = "/message/updateNotifications";
        $.ajax({
            method: "GET",
            url: url,
            data: {
                type: 'Event',
                start: start,
                template: template
            },
            success: function (response) {
                element.removeClass("loading");
                try {
                    response = JSON.parse(response);
                } catch (e) {
                    response = false;
                    return;
                }
                if (response.success) {

                    element.append(response.fragment);
                } else {
                    element.data("start", -1);
                }

            },
            error: function () {

            }
        });
    }

}
