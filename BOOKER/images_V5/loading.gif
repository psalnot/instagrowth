<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <title></title>
	<style type="text/css">
		body {text-align:center;background:#333333;font:normal 16px Arial}
		div#popup {margin:100px auto;text-align:left;border:0px; width:400px; padding:20px;background:white;}
		img#logo {width:360px;}
		a.camscape,a.c-hosting,a.c-software,a.c-admin {text-decoration:none;}
		a.camscape{color:#2191B6!important;font-weight:bold;}
		a.c-hosting{color:red!important;}
		a.c-software{color:blue!important;}
		a.c-admin{color:green!important;}
		div.c-links {font-weight:normal;font-size:x-small;text-align:left;font-family:Arial,sans-serif;}
		div.left {text-align:left;font-size:small;}
	</style>
  </head>
  <body>
	<div id="popup">
		<h2>It Works!</h2>
		<div class="left">
		    The server works fine, don't worry!
		</div>
	</div>
  </body>
</html>
